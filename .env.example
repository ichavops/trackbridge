# Resend API key — get yours at https://resend.com
RESEND_API_KEY=re_your_api_key_here

# Email address that receives contact form submissions
# Set to your real inbox — no verification needed, this is just the delivery target
CONTACT_EMAIL_TO=hello@trackbridge.ai

# Sender address shown in outbound emails
# Use onboarding@resend.dev until trackbridge.ai is verified inside Resend (Domains tab)
# Once verified: TrackBridge <hello@trackbridge.ai>
CONTACT_EMAIL_FROM=onboarding@resend.dev

# Admin panel password — generate with: openssl rand -base64 32
ADMIN_PASSWORD=your-strong-password-here

# Bump this number (e.g. 1 → 2) in Vercel to instantly revoke all admin sessions
# without changing ADMIN_PASSWORD
ADMIN_SESSION_VERSION=1

# Calendly personal access token — Settings → Integrations → API & Webhooks
# IMPORTANT: this token gives read access to your bookings — never commit a real value
CALENDLY_API_TOKEN=your_calendly_token_here

# Your Calendly booking page URL (baked into client bundle at build time — set BEFORE deploying)
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/your-username/trackbridge-demo
